# Server Config
PORT=3001
NODE_ENV=production

# CORS (Change to your frontend domain in production)
CORS_ORIGIN=http://localhost:3000

# Gemini AI Key (Get from Google AI Studio: https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# File Limits
MAX_FILE_SIZE_MB=10

# AI Configuration
AI_BATCH_SIZE=25
AI_MAX_RETRIES=3
AI_RETRY_DELAY_MS=1000
